{
  "name": "fameticker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--no-experimental-webstorage\" next dev -H 0.0.0.0 --turbopack",
    "dev:no-turbo": "NODE_OPTIONS=\"--no-experimental-webstorage\" next dev -H 0.0.0.0",
    "build": "NODE_OPTIONS=\"--no-experimental-webstorage\" next build",
    "start": "NODE_OPTIONS=\"--no-experimental-webstorage\" next start",
    "lint": "bunx tsc --noEmit && next lint",
    "format": "bunx biome format --write"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.503.0",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.17.50",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
